<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <springProperty scope="context" name="springAppName" source="spring.application.name"/>
    <springProperty scope="context" name="slackWebhookUrl" source="slack.webhook-url" defaultValue=""/>
    <springProperty scope="context" name="slackChannel" source="slack.channel" defaultValue="#alerts"/>
    <springProperty scope="context" name="slackEnvironment" source="slack.environment" defaultValue="UNKNOWN"/>

    <!-- 중복 알림 방지 TurboFilter (ERROR 레벨 1분 쿨다운) -->
    <turboFilter class="com.samhap.kokomen.global.logging.RateLimitingTurboFilter">
        <cooldownSeconds>60</cooldownSeconds>
    </turboFilter>

    <!-- 공통 Appender 정의 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                <![CDATA[[%X{requestId:-noRequest}] %d{yyyy-MM-dd HH:mm:ss.SSS} ${springAppName:-kokomen-interview} [%thread] %-5level %logger{36} - %msg%n]]>
            </pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>./logs/app.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>
                <![CDATA[[%X{requestId:-noRequest}] %d{yyyy-MM-dd HH:mm:ss.SSS} ${springAppName:-kokomen-interview} [%thread] %-5level %logger{36} - %msg%n]]>
            </pattern>
        </encoder>
    </appender>

    <!-- Slack Appender -->
    <appender name="SLACK" class="com.github.maricn.logback.SlackAppender">
        <webhookUri>${slackWebhookUrl}</webhookUri>
        <channel>${slackChannel}</channel>
        <username>Kokomen-Alert-Bot</username>
        <iconEmoji>:rotating_light:</iconEmoji>
        <colorCoding>true</colorCoding>
        <layout class="com.samhap.kokomen.global.logging.SlackErrorLayout">
            <environment>${slackEnvironment}</environment>
        </layout>
    </appender>

    <!-- Slack Async Appender (비동기 + ERROR 필터) -->
    <appender name="ASYNC_SLACK" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="SLACK"/>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <queueSize>500</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
    </appender>

    <!-- local 환경: 콘솔만 사용 -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- dev 환경: FILE 저장 + Slack 알림 -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ASYNC_SLACK"/>
        </root>
    </springProfile>

    <!-- prod 환경: FILE 저장 + Slack 알림 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ASYNC_SLACK"/>
        </root>
    </springProfile>

    <!-- load-test 환경: FILE 저장 -->
    <springProfile name="load-test">
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- test 환경: 콘솔만 사용 -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- docs 환경: 콘솔만 사용 -->
    <springProfile name="docs">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
